# =============================================================================
# ESP32-C6 Board Configuration for CSI/WiFi Sensing
# =============================================================================

# CSI Support (required for Channel State Information extraction)
CONFIG_ESP_WIFI_CSI_ENABLED=y

# Power saving modes can cause packet loss and timing issues with CSI callbacks
CONFIG_PM_ENABLE=n
CONFIG_ESP_WIFI_STA_DISCONNECTED_PM_ENABLE=n

# Optimized scheduler: Improved task switching performance
CONFIG_FREERTOS_OPTIMIZED_SCHEDULER=y

# Higher tick rate: reduces callback latency by 10x compared to default 100Hz
CONFIG_FREERTOS_HZ=1000

# ESP32-C6 is single core, use unicore configuration
CONFIG_FREERTOS_UNICORE=y

# WiFi 6 (802.11ax) support
CONFIG_ESP_WIFI_11AX_SUPPORT=y
