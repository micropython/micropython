
#
# Driver: MCH2022 rp2040 driver
#
# CONFIG_DRIVER_MCH22_RP2040_ENABLE is not set
# end of Driver: MCH2022 rp2040 driver

#
# Firmware & device configuration
#
CONFIG_INFO_FIRMWARE_NAME="Unknown"
CONFIG_INFO_FIRMWARE_BUILD=0
CONFIG_INFO_HARDWARE_NAME="Generic device"
CONFIG_MICROPY_FROZEN_MANIFEST="manifest.py"
CONFIG_INFO_HARDWARE_WOEZEL_NAME="generic"
CONFIG_OTA_WEB_SERVER="badge.team"
CONFIG_OTA_WEB_USE_HTTPS=y
CONFIG_OTA_WEB_PORT=443
CONFIG_OTA_WEB_PATH="/firmware/unknown.bin"
CONFIG_OTA_WEB_VERSION_PATH="/firmware/version/unknown.txt"
CONFIG_WOEZEL_WEB_SERVER="badge.team"
CONFIG_WIFI_SSID="badge"
CONFIG_WIFI_PASSWORD=""
CONFIG_DEFAULT_DISPLAY_ORIENTATION_LANDSCAPE=y
# CONFIG_DEFAULT_DISPLAY_ORIENTATION_PORTRAIT is not set
# CONFIG_DEFAULT_DISPLAY_ORIENTATION_REVERSE_LANDSCAPE is not set
# CONFIG_DEFAULT_DISPLAY_ORIENTATION_REVERSE_PORTRAIT is not set
# CONFIG_FW_ENABLE_SHA2017_DISOBEY2019_PARTITION_TABLE_UPGRADE is not set
# CONFIG_FW_DISABLE_OTA_AND_FIRSTBOOT is not set
# end of Firmware & device configuration

#
# Driver: Audio mixer
#
CONFIG_DRIVER_SNDMIXER_ENABLE=y
CONFIG_DRIVER_SNDMIXER_I2S_PORT0=y
# CONFIG_DRIVER_SNDMIXER_I2S_PORT1 is not set
# CONFIG_DRIVER_SNDMIXER_I2S_DAC_EXTERNAL is not set
# CONFIG_DRIVER_SNDMIXER_I2S_DAC_EXTERNAL_MSB is not set
CONFIG_DRIVER_SNDMIXER_I2S_DAC_EXTERNAL_LSB=y
# CONFIG_DRIVER_SNDMIXER_I2S_DAC_INTERNAL is not set
CONFIG_DRIVER_SNDMIXER_PIN_MCK=30
CONFIG_DRIVER_SNDMIXER_PIN_BCK=29
CONFIG_DRIVER_SNDMIXER_PIN_WS=31
CONFIG_DRIVER_SNDMIXER_PIN_DATA_OUT=28
CONFIG_DRIVER_SNDMIXER_I2S_CHANNEL_FORMAT_RL=y
# CONFIG_DRIVER_SNDMIXER_I2S_CHANNEL_FORMAT_AL is not set
# CONFIG_DRIVER_SNDMIXER_I2S_CHANNEL_FORMAT_AR is not set
# CONFIG_DRIVER_SNDMIXER_I2S_CHANNEL_FORMAT_OL is not set
# CONFIG_DRIVER_SNDMIXER_I2S_CHANNEL_FORMAT_OR is not set
CONFIG_DRIVER_SNDMIXER_I2S_DATA_FORMAT_UNSIGNED=y
# CONFIG_DRIVER_SNDMIXER_I2S_DATA_FORMAT_SIGNED is not set
CONFIG_DRIVER_SNDMIXER_SAMPLE_RATE=20000
CONFIG_DRIVER_SNDMIXER_BITS_PER_SAMPLE=16
CONFIG_DRIVER_SNDMIXER_BUFFZIE=4096
# CONFIG_DRIVER_SNDMIXER_DEBUG is not set
# end of Driver: Audio mixer

#
# Driver: framebuffer support
#
CONFIG_DRIVER_FRAMEBUFFER_ENABLE=y
# CONFIG_DRIVER_FRAMEBUFFER_FLIP is not set
CONFIG_DRIVER_FRAMEBUFFER_SWAP_R_AND_B=y
CONFIG_DRIVER_FRAMEBUFFER_BIG_ENDIAN=y
# CONFIG_DRIVER_FRAMEBUFFER_CORRECT_GAMMA is not set
# CONFIG_DRIVER_FRAMEBUFFER_CORRECT_GB is not set
# CONFIG_G_MATRIX_ENABLE is not set
# end of Driver: framebuffer support

#
# Driver: ILI9341 LCD display
#
# end of Driver: ILI9341 LCD display

#
# Driver: Badge BSP display
#
CONFIG_DRIVER_BADGE_BSP_ENABLE=y
# end of Driver: Badge BSP display

#
# Driver: RTC memory
#

#
# Buses
#
# CONFIG_BUS_VSPI_ENABLE is not set
# CONFIG_BUS_HSPI_ENABLE is not set
# CONFIG_BUS_I2C0_ENABLE is not set
# CONFIG_BUS_I2C1_ENABLE is not set
# end of Buses

#
# mDNS
#
CONFIG_MDNS_MAX_INTERFACES=3
CONFIG_MDNS_MAX_SERVICES=10
CONFIG_MDNS_TASK_PRIORITY=1
CONFIG_MDNS_TASK_STACK_SIZE=4096
# CONFIG_MDNS_TASK_AFFINITY_NO_AFFINITY is not set
CONFIG_MDNS_TASK_AFFINITY_CPU0=y
# CONFIG_MDNS_TASK_AFFINITY_CPU1 is not set
CONFIG_MDNS_TASK_AFFINITY=0x0
CONFIG_MDNS_SERVICE_ADD_TIMEOUT_MS=2000
CONFIG_MDNS_TIMER_PERIOD_MS=100
# CONFIG_MDNS_NETWORKING_SOCKET is not set
# CONFIG_MDNS_SKIP_SUPPRESSING_OWN_QUERIES is not set
# CONFIG_MDNS_ENABLE_DEBUG_PRINTS is not set
# CONFIG_MDNS_RESPOND_REVERSE_QUERIES is not set
CONFIG_MDNS_MULTIPLE_INSTANCE=y

#
# MDNS Predefined interfaces
#
CONFIG_MDNS_PREDEF_NETIF_STA=y
CONFIG_MDNS_PREDEF_NETIF_AP=y
# end of MDNS Predefined interfaces
# end of mDNS

#
# FreeRTOS
#
CONFIG_FREERTOS_NO_AFFINITY=0x7FFFFFFF
# end of FreeRTOS

#
# LWIP-MOCK-CONFIG
#
CONFIG_LWIP_IPV6=y
# end of LWIP-MOCK-CONFIG

#
# CMake Utilities
#
# CONFIG_CU_RELINKER_ENABLE is not set
# CONFIG_CU_DIAGNOSTICS_COLOR_NEVER is not set
CONFIG_CU_DIAGNOSTICS_COLOR_ALWAYS=y
# CONFIG_CU_DIAGNOSTICS_COLOR_AUTO is not set
# CONFIG_CU_GCC_LTO_ENABLE is not set
# CONFIG_CU_GCC_STRING_1BYTE_ALIGN is not set
# end of CMake Utilities

#
# Badge.Team BSP
#
# CONFIG_BSP_TARGET_STUB is not set
CONFIG_BSP_TARGET_TANMATSU=y
# CONFIG_BSP_TARGET_KAMI is not set
# CONFIG_BSP_TARGET_KONSOOL is not set
# CONFIG_BSP_TARGET_MCH2022 is not set
# CONFIG_BSP_TARGET_HACKERHOTEL_2024 is not set
# CONFIG_BSP_TARGET_ESP32_P4_FUNCTION_EV_BOARD is not set
# CONFIG_BSP_TARGET_BORNHACK_2024_POV is not set
# CONFIG_BSP_TARGET_BORNHACK_2025_CIRCLE is not set
# end of Badge.Team BSP
